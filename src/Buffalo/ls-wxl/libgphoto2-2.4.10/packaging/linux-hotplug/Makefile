install-hotplugdocDATA: $(hotplugdoc_DATA)
	@$(NORMAL_INSTALL)
	test -z "$(hotplugdocdir)" || $(MKDIR_P) "$(DESTDIR)$(hotplugdocdir)"
	@list='$(hotplugdoc_DATA)'; test -n "$(hotplugdocdir)" || list=; \
	for p in $$list; do \
	  if test -f "$$p"; then d=; else d="$(srcdir)/"; fi; \
	  echo "$$d$$p"; \
	done | $(am__base_list) | \
	while read files; do \
	  echo " $(INSTALL_DATA) $$files '$(DESTDIR)$(hotplugdocdir)'"; \
	  $(INSTALL_DATA) $$files "$(DESTDIR)$(hotplugdocdir)" || exit $$?; \
	done

uninstall-hotplugdocDATA:
	@$(NORMAL_UNINSTALL)
	@list='$(hotplugdoc_DATA)'; test -n "$(hotplugdocdir)" || list=; \
	files=`for p in $$list; do echo $$p; done | sed -e 's|^.*/||'`; \
	test -n "$$files" || exit 0; \
	echo " ( cd '$(DESTDIR)$(hotplugdocdir)' && rm -f" $$files ")"; \
	cd "$(DESTDIR)$(hotplugdocdir)" && rm -f $$files
